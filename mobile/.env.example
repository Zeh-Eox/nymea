# EXPO_PUBLIC_* vars are inlined into the JS bundle at build time.
# Android emulator: use 10.0.2.2 to reach the host. iOS sim/web: localhost works.
EXPO_PUBLIC_API_BASE_URL=http://10.0.2.2:4000/api

# Firebase client config (push notifications, phase 9+)
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=
